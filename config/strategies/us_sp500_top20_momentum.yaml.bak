# =============================================================
# STRATEGY CONFIG — a strategy is DATA, not code.
# This file is what the no-code strategy builder will eventually emit.
# =============================================================

strategy_id: us_sp500_top20_momentum
name: "S&P 500 Top-20 Momentum"
description: "Honest default: rank the POINT-IN-TIME S&P 500 by 12-2 momentum, hold top 20 equal-weight, rebalance monthly. This is the config our own signal-grid found most robust across both eras (+3.2%/+2.7% vs SPY)."

market: us                      # -> config/markets/us.yaml
universe: sp500_pit             # POINT-IN-TIME. Using the plain `sp500` (today's
                                # list) inflates results by ~9%/yr of pure
                                # inclusion bias -- see scripts/validate.py.

signal:
  name: momentum                # raw 12-2 total return.
                                # Our signal grid (scripts/experiment_signal.py)
                                # showed raw momentum beats volar in BOTH eras;
                                # dividing by volatility was our weakest choice.
                                # Volar remains available -- just not the default.
  params:
    lookback_months: 12
    skip_months: 1              # skip most recent month (short-term reversal)

selection:
  top_n: 25

weighting:
  method: equal                 # equal | inverse_vol | capped
  max_position_weight: 0.10
  max_sector_weight: 0.25

rebalance:
  frequency: monthly            # weekly | monthly | quarterly
  day: first_trading_day

overlay:
  # ADOPTED as default (see DECISIONS.md). On SURVIVORSHIP-FREE data, 2005-2026, the
  # trend filter costs ~1.4pt of CAGR but cuts max drawdown from -64.9% to -34.0% AND
  # raises Sharpe (0.71->0.82) and Sortino (1.24->1.49). It is not merely insurance:
  # it improves return-per-unit-risk, and -34% is a drawdown a real investor can
  # survive whereas -65% is not (a strategy nobody holds to the bottom does not earn
  # its paper CAGR). Set enabled: false to see the raw, unprotected strategy.
  trend_filter:
    enabled: true
    benchmark_ma_days: 200      # invest only while benchmark > its 200d MA
    action_when_off: cash

backtest:
  start: "2005-01-01"
  end: today          # `today` keeps the test period fresh. A hard-coded
                      # end date silently discards your most recent data.
